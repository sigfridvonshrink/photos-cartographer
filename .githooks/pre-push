# Run static guards + the test suite before pushing; abort the push if anything fails.
# Enable for your clone with:  git config core.hooksPath .githooks
# Bypass for a single push with: git push --no-verify

# Cheap static guard first (fail fast): no production function may be referenced only by tests.
echo "pre-push: checking for test-only production functions..."
if ! python3 .githooks/check_test_only_functions.py; then
    echo
    echo "pre-push: test-only-functions guard FAILED — push aborted."
    echo "          (override with 'git push --no-verify')"
    exit 1
fi

echo "pre-push: running test suite (fast subset; slow real-fixture tests run in CI)..."
if ! python3 -m pytest -q -m "not slow"; then
    echo
    echo "pre-push: tests FAILED — push aborted."
    echo "          (override with 'git push --no-verify')"
    exit 1
fi
echo "pre-push: tests passed."

# Decision-editor front-end unit tests (Node's built-in runner; no deps). Skip with a notice if Node
# isn't installed locally — CI runs them regardless.
if command -v node >/dev/null 2>&1; then
    echo "pre-push: running decision-editor front-end tests..."
    if ! node --test ingest/photos_pipeline/editor/tests/*.test.mjs >/dev/null 2>&1; then
        echo
        echo "pre-push: front-end tests FAILED — push aborted (run 'tools/jstest' to see details)."
        echo "          (override with 'git push --no-verify')"
        exit 1
    fi
    echo "pre-push: front-end tests passed."
else
    echo "pre-push: node not found — skipping front-end tests (CI will run them)."
fi

# The photos-cartographer executable must build and run (ingest/dist is gitignored, not committed).
echo "pre-push: checking the photos-cartographer build assembles and runs..."
if ! python3 tools/build-pyz --check; then
    echo
    echo "pre-push: photos-cartographer build is broken — push aborted."
    echo "          (override with 'git push --no-verify')"
    exit 1
fi
exit 0
