#!/usr/bin/env python3
"""Bundle decision-editor.unbundled + web/ + examples/ into the standalone single-file decision-editor.

The source (`decision-editor.unbundled`) reads its front-end and demo fixtures from sibling directories.
This generator embeds those assets inline — replacing the marked ASSET LAYER block — so the resulting
`decision-editor` is one self-contained file you can copy anywhere a `python3` lives and run directly.

  ./bundle           regenerate decision-editor from the current source + assets
  ./bundle --check   exit nonzero if decision-editor is missing or out of sync with the source/assets
                     (a CI / pre-push guard — catches a stale bundle OR a hand-edit of the generated
                     file, since both make the on-disk bundle differ from a fresh regeneration)

Stdlib only; deterministic (sorted asset order, no timestamps) so --check is a plain byte comparison.
"""
import argparse
import base64
import hashlib
import os
import sys
import textwrap

HERE = os.path.dirname(os.path.abspath(__file__))
SOURCE = os.path.join(HERE, "decision-editor.unbundled")
OUTPUT = os.path.join(HERE, "decision-editor")
WEB = os.path.join(HERE, "web")
EXAMPLES = os.path.join(HERE, "examples")

BEGIN = "# >>> ASSET LAYER — bundler-replaced >>>"
END = "# <<< ASSET LAYER <<<"


def _collect(root):
    """{posix-relative-path: bytes} for every file under `root`, sorted by path for determinism."""
    out = {}
    for dirpath, _dirs, files in os.walk(root):
        for name in files:
            full = os.path.join(dirpath, name)
            rel = os.path.relpath(full, root).replace(os.sep, "/")
            with open(full, "rb") as f:
                out[rel] = f.read()
    return {k: out[k] for k in sorted(out)}


def _emit_dict(varname, assets):
    """A `name = { key: _b("base64"...), ... }` literal, base64 wrapped across adjacent string lines."""
    lines = [f"{varname} = {{"]
    for key in assets:  # already sorted by _collect
        b64 = base64.b64encode(assets[key]).decode("ascii")
        chunks = textwrap.wrap(b64, 116) or [""]
        lines.append(f"    {key!r}: _b(")
        lines.extend(f"        {c!r}" for c in chunks)
        lines.append("    ),")
    lines.append("}")
    return "\n".join(lines)


def _render_block(web, examples):
    """The replacement text for the ASSET LAYER region: a base64 helper, the two asset dicts, and
    dict-lookup accessors with the same signatures the rest of the script calls."""
    return "\n".join([
        BEGIN,
        "# GENERATED — assets embedded inline by ./bundle. DO NOT EDIT this block (or this file) by",
        "# hand; your changes are lost on the next bundle. Edit decision-editor.unbundled and re-run",
        "# ./bundle. The rest of this file is verbatim from the source.",
        "import base64 as _base64",
        "",
        "",
        "def _b(s):",
        "    return _base64.b64decode(s)",
        "",
        "",
        _emit_dict("_WEB_ASSETS", web),
        "",
        "",
        _emit_dict("_EXAMPLE_ASSETS", examples),
        "",
        "",
        "def _web_asset(rel):",
        "    return _WEB_ASSETS.get(rel)",
        "",
        "",
        "def _example_bytes(name):",
        "    return _EXAMPLE_ASSETS.get(name)",
        END,
    ])


def _insert_banner(text, src_sha):
    """Insert a loud GENERATED banner just after the shebang line."""
    bar = "# " + "=" * 76
    banner = "\n".join([
        bar,
        "# GENERATED FILE — DO NOT EDIT.  Built from decision-editor.unbundled by ./bundle.",
        "# Edit the source and re-run ./bundle; edits here are lost.  Verify with ./bundle --check.",
        f"# source-sha256: {src_sha}",
        bar,
        "",
    ])
    shebang, sep, rest = text.partition("\n")
    if shebang.startswith("#!"):
        return shebang + "\n" + banner + rest
    return banner + text


def build():
    """The full text of the bundled decision-editor, generated from the current source + assets."""
    with open(SOURCE, encoding="utf-8") as f:
        src = f.read()
    if BEGIN not in src or END not in src:
        sys.exit(f"error: ASSET LAYER markers not found in {SOURCE}")
    head, _, rest = src.partition(BEGIN)
    _, _, tail = rest.partition(END)
    block = _render_block(_collect(WEB), _collect(EXAMPLES))
    body = head + block + tail
    body = _insert_banner(body, hashlib.sha256(src.encode("utf-8")).hexdigest())
    if not body.endswith("\n"):
        body += "\n"
    return body


def main():
    ap = argparse.ArgumentParser(description="Bundle the decision editor into a single self-contained file.")
    ap.add_argument("--check", action="store_true",
                    help="verify the committed decision-editor matches the source+assets; exit nonzero if not")
    args = ap.parse_args()

    content = build()
    if args.check:
        if not os.path.isfile(OUTPUT):
            sys.exit("out of sync: decision-editor does not exist — run ./bundle")
        with open(OUTPUT, encoding="utf-8") as f:
            current = f.read()
        if current != content:
            sys.exit("out of sync: decision-editor differs from the source/assets — run ./bundle "
                     "(or revert a hand-edit of the generated file)")
        print("decision-editor is in sync with the source and assets.")
        return
    with open(OUTPUT, "w", encoding="utf-8") as f:
        f.write(content)
    os.chmod(OUTPUT, 0o755)
    print(f"wrote {OUTPUT} ({os.path.getsize(OUTPUT):,} bytes)")


if __name__ == "__main__":
    main()
