class RootGuard:
    @staticmethod
    def check_sentinel(workspace_root: str):
        from photos_utils import guard_path
        guard = guard_path(workspace_root)
        if not os.path.exists(guard):
            raise RuntimeError(f"Workspace guard missing: expected {guard}. Are you in the correct workspace root?")

    @staticmethod
    def resolve_and_check_path(base_dir: str, target_path: str, must_be_relative: bool = True) -> str:
        """
        Resolves a path safely.
        Rejects absolute paths if expected to be relative.
        Rejects .. traversal.
        Rejects symlink escapes.
        Proves containment within base_dir.
        """
        if must_be_relative and os.path.isabs(target_path):
            raise ValueError(f"Path must be relative, but absolute path provided: {target_path}")

        # Check for .. traversal explicitly in the raw string
        if ".." in target_path.split(os.sep):
            raise ValueError(f"Directory traversal (..) not allowed in path: {target_path}")

        full_path = os.path.join(base_dir, target_path)
        resolved_path = os.path.realpath(full_path)
        resolved_base = os.path.realpath(base_dir)

        try:
            common = os.path.commonpath([resolved_base, resolved_path])
        except ValueError:
            raise ValueError(f"Path validation failed: {target_path} is not on the same mount as {base_dir}")

        if common != resolved_base:
            raise ValueError(f"Path escape detected: {target_path} resolves outside {base_dir}")

        return resolved_path

    @staticmethod
    def check_case_insensitive_conflict(existing_paths: set, new_path: str) -> None:
        """
        Checks for case-insensitive conflicts against a set of known lowercased paths.
        Raises ValueError if a conflict is detected.
        (Retained for phase 2 safety core testing support).
        """
        lower_new = new_path.lower()
        if lower_new in existing_paths:
            raise ValueError(f"Case-insensitive path conflict detected for: {new_path}")
        existing_paths.add(lower_new)

class InventoryScanner:
    @classmethod
    def scan_workspace(cls, root_dir: str) -> Dict[str, InventoryRecord]:
        inventory = {}
        for root, dirs, files in os.walk(root_dir):
            # Skip every dot-directory wholesale: .photos-ingest/, .photos-ingest-quarantine/,
            # .photos-ingest-backups/, .git/, and the default gpx_root (.photos-ingest/gpx/).
            # Nothing pipeline-related lives outside a dot path, so this one rule replaces the
            # old per-filename allow-list (shared contract Section 5 / prep Section 3).
            dirs[:] = [d for d in dirs if not d.startswith('.')]

            for filename in files:
                if filename.startswith('.'):
                    continue

                # Ignore __std.* for logical inventory semantics across both workspace and library
                if filename.startswith('__std.'):
                    continue

                rel_path = os.path.relpath(os.path.join(root, filename), root_dir)
                try:
                    record = cls.scan_file(root_dir, rel_path, "workspace", "scan")
                    inventory[rel_path] = record
                except FileNotFoundError:
                    pass
        return inventory

    @staticmethod
    def scan_file(root_dir: str, rel_path: str, root_kind: str, stage: str) -> InventoryRecord:
        """
        Captures the immutable file state of a single file.
        """
        abs_path = os.path.join(root_dir, rel_path)
        stat = os.stat(abs_path)

        filename = os.path.basename(abs_path)
        ext = os.path.splitext(filename)[1].lower().lstrip('.')

        # Simple media class detection for prep organization
        from photos_utils import media_class_for_ext
        media_class = media_class_for_ext(ext)

        return InventoryRecord(
            inventory_id=f"inv-{uuid.uuid4().hex[:8]}",
            root_kind=root_kind,
            stage=stage,
            absolute_path=abs_path,
            relative_path=rel_path,
            filename=filename,
            extension=ext,
            media_class=media_class,
            size=stat.st_size,
            mtime_ns=stat.st_mtime_ns,
            device=stat.st_dev,
            inode=stat.st_ino
        )


