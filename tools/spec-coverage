"""spec-coverage — report which curated spec clauses still have a test, and gate on regressions.

Cross-references the clause registry (spec/spec-clauses.json) against the live test suite's
`@pytest.mark.spec("<clause-id>")` tags (gathered by a collection-only pytest pass, via the
`--spec-dump` hook in tests/conftest.py). Prints a covered/uncovered report and EXITS NON-ZERO if any
registered clause has lost its test — a regression gate the line/branch coverage report can't provide.

This is a MAP, not a quality score: a tag asserts a test EXISTS for a clause, not that it is a good
test — the real assertion lives in the test body. Run from anywhere:

    tools/spec-coverage              # summary + any uncovered (gate: non-zero if uncovered)
    tools/spec-coverage --verbose    # full per-clause table
    tools/spec-coverage --json       # machine-readable result
"""
import argparse
import json
import os
import subprocess
import sys
import tempfile

ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
REGISTRY = os.path.join(ROOT, "spec", "spec-clauses.json")


def _collect_tagged():
    """{clause_id: [test nodeids]} from a collection-only pytest pass (no tests run)."""
    fd, dump = tempfile.mkstemp(prefix="spec-cov-", suffix=".json")
    os.close(fd)
    try:
        proc = subprocess.run(
            [sys.executable, "-m", "pytest", "--collect-only", "-q", "-p", "no:cacheprovider",
             f"--spec-dump={dump}"],
            cwd=ROOT, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
        if not os.path.exists(dump) or os.path.getsize(dump) == 0:
            sys.stderr.write("spec-coverage: collection produced no dump — pytest output:\n")
            sys.stderr.write(proc.stdout[-2000:] + "\n")
            sys.exit(2)
        with open(dump) as f:
            return json.load(f)
    finally:
        if os.path.exists(dump):
            os.remove(dump)


def main():
    ap = argparse.ArgumentParser(description="Report + gate spec-clause test coverage.")
    ap.add_argument("--verbose", action="store_true", help="list every clause and its test(s)")
    ap.add_argument("--json", action="store_true", help="emit the result as JSON")
    args = ap.parse_args()

    with open(REGISTRY) as f:
        clauses = json.load(f)["clauses"]
    tagged = _collect_tagged()

    # The registry is the living clause INDEX (every spec clause + its spec pointer). The GATE applies
    # only to `must_cover` clauses — the curated safety subset that must keep a test. Other clauses are
    # tracked (and may carry a test) but not gated; tagging more of them grows the gated set over time.
    must = [c for c in clauses if c.get("must_cover")]
    uncovered = [c["id"] for c in must if not tagged.get(c["id"])]
    registered_ids = {c["id"] for c in clauses}
    extra = sorted(cid for cid in tagged if cid not in registered_ids)   # tagged but not in the index
    tagged_total = sum(1 for c in clauses if tagged.get(c["id"]))

    if args.json:
        print(json.dumps({
            "clauses_total": len(clauses), "must_cover": len(must),
            "must_cover_covered": len(must) - len(uncovered), "uncovered_must_cover": uncovered,
            "tagged_total": tagged_total, "extra_untracked": extra,
            "coverage": {c["id"]: tagged.get(c["id"], []) for c in clauses},
        }, indent=2))
        return 1 if uncovered else 0

    if args.verbose:
        for c in sorted(clauses, key=lambda c: (not c.get("must_cover"), c["area"], c["id"])):
            tests = tagged.get(c["id"], [])
            flag = "GATE" if c.get("must_cover") else "    "
            mark = "ok " if tests else ("GAP" if c.get("must_cover") else "-  ")
            sp = c.get("spec", {})
            print(f"  [{flag} {mark}] {c['id']:46} ({c['area']}, {c['criticality']}) "
                  f"{sp.get('file', '?')} §{sp.get('section', '?')}  {len(tests)} test(s)")

    print(f"\nspec-coverage: {len(clauses)} clauses indexed; {tagged_total} have a test. "
          f"Gate: {len(must) - len(uncovered)}/{len(must)} must-cover clauses covered.")
    if extra:
        print(f"  note: {len(extra)} tagged clause(s) not in the index: " + ", ".join(extra))
    if uncovered:
        print(f"\nFAIL — {len(uncovered)} must-cover clause(s) lost their test:")
        for cid in uncovered:
            print(f"  - {cid}")
        print("\nRe-tag a test with @pytest.mark.spec(\"<id>\"), or clear must_cover in "
              "spec/spec-clauses.json if it was intentionally dropped.")
        return 1
    print("All must-cover spec clauses are covered. ✓")
    return 0


if __name__ == "__main__":
    sys.exit(main())
